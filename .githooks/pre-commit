#!/bin/bash
# Pre-commit hook: block commits containing API keys or secrets

echo "Running secret scan..."

# Build patterns dynamically to avoid self-matching
ANT_PREFIX="sk-"
ANT_PREFIX="${ANT_PREFIX}ant-"
PATTERNS=(
  "$ANT_PREFIX"
  "BEGIN.*PRIVATE KEY"
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

for FILE in $STAGED_FILES; do
  # Skip the hook file itself
  if [[ "$FILE" == *"pre-commit"* ]]; then
    continue
  fi
  for PATTERN in "${PATTERNS[@]}"; do
    if git show ":$FILE" 2>/dev/null | grep -qE "$PATTERN"; then
      echo ""
      echo "ERROR: Potential secret detected in $FILE"
      echo "  Matched an API key or private key pattern."
      echo ""
      echo "Remove the secret and try again."
      exit 1
    fi
  done
done

echo "No secrets found. Proceeding with commit."
exit 0
